# Auto-detect text files and normalize line endings
* text=auto

# Python source files
*.py text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Batch files (must stay CRLF on Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Configuration files
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Lock and generated files
*.lock -text
*.exe -text
*.png -text
*.jpg -text
*.ico -text

# Makefile
Makefile text eol=lf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf
